{
  "name": "lineage-generator",
  "version": "0.0.0",
  "license": "MIT",
  "author": "gameroman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infinite-craft-community/lineage-generator.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "bun test --parallel=6",
    "lint": "oxlint",
    "format": "oxfmt",
    "prof": "bun --cpu-prof-md --cpu-prof-dir ./profiling src",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "savefile.js": "0.0.3"
  },
  "devDependencies": {
    "@gameroman/config": "0.1.0",
    "@savefile/fixtures": "0.0.1",
    "@types/bun": "1.3.14",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  }
}
