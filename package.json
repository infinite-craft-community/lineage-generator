{
  "name": "lineage-generator",
  "version": "0.0.0",
  "license": "MIT",
  "author": "gameroman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infinite-craft-community/lineage-generator.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "bun test tests/hybrid.test.ts tests/infinibrowser.test.ts tests/infinibrowser-alternative-depth-calculation.test.ts",
    "test:catstone": "bun test tests/catstone.test.ts --timeout=60000",
    "lint": "oxlint",
    "format": "oxfmt",
    "prof": "bun --cpu-prof-md --cpu-prof-dir ./profiling/profilings profiling/index.ts",
    "bench": "bun --expose-gc benchmarks/fast.ts",
    "bench:catstone": "bun --expose-gc benchmarks/catstone.ts",
    "bench:init": "bun --expose-gc benchmarks/init.ts",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "savefile.js": "0.1.0"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.5",
    "@infinite-craft/dom-types": "0.0.4",
    "@savefile/fixtures": "0.0.1",
    "@types/bun": "1.3.14",
    "mitata": "1.0.34",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "0.25.0",
    "tsdown": "0.22.7",
    "typescript": "6.0.3"
  }
}
